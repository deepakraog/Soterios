{
  "name": "soterios",
  "version": "1.0.2",
  "description": "A local-first desktop toolkit for system maintenance, monitoring, and basic security checks.",
  "main": "src/main/main.js",
  "author": "Soterios",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "postinstall": "node scripts/download-clamav.js",
    "prepack": "node scripts/download-clamav.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "ps-list": "^8.1.1",
    "systeminformation": "^5.23.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "adm-zip": "^0.5.17",
    "axios": "^1.18.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.soterios.app",
    "productName": "Soterios",
    "copyright": "Copyright (c) 2026 Chris Rivera",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "asarUnpack": [
      "assets/clamav/**"
    ],
    "files": [
      "src/main/main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "publisherName": "Chris Rivera",
      "signAndEditExecutable": true,
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Soterios",
      "menuCategory": true,
      "license": "build/LICENSE.txt",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}
